{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "shadcn-admin-tauri",
  "version": "2.2.1",
  "identifier": "com.shadcn.admin.tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm prepare:tauri-resources"
  },
  "app": {
    "windows": [
      {
        "title": "shadcn-admin-tauri",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/",
      "vendor/libreoffice/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "linux": {
      "deb": {
        "depends": [
          "libreoffice",
          "p7zip-full"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0NjE3RTU1M0VBQ0ExClJXU2hyRDVWZm1IMEFNZU80MzRYd0lVTEdkU1k2SStCQmMydUJLcXYzQUREeXVMWlhZK3NyZk1CCg==",
      "endpoints": [
        "https://github.com/15257703071/FDR/releases/latest/download/latest.json"
      ]
    }
  }
}
